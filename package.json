{
  "name": "employee-management-dashboard",
  "version": "1.0.0",
  "description": "Employee Management Backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "npm run build && sequelize-cli db:migrate",
    "migrate:undo": "npm run build && sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npm run build && sequelize-cli db:migrate:undo:all",
    "seed": "npm run build && sequelize-cli db:seed:all",
    "seed:undo": "npm run build && sequelize-cli db:seed:undo:all"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "@types/sequelize": "^4.28.20",
    "@types/uuid": "^10.0.0",
    "sequelize-cli": "^6.6.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
